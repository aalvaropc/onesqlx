# OneSQLx Environment Variables
# Copy this file to .env for local overrides (not loaded automatically).
# Phoenix uses config/runtime.exs — these are documented for reference.

# ── Database (dev defaults) ──────────────────────────────────────────
DATABASE_URL=ecto://postgres:postgres@localhost/onesqlx_dev

# ── Phoenix ──────────────────────────────────────────────────────────
SECRET_KEY_BASE=generate-with-mix-phx.gen.secret
PHX_HOST=localhost
PORT=4000
# PHX_SERVER=true  # Enable in production

# ── External test database (docker-compose db_external) ──────────────
# Used for integration tests against a real external PostgreSQL
EXTERNAL_DB_HOST=localhost
EXTERNAL_DB_PORT=5433
EXTERNAL_DB_USER=postgres
EXTERNAL_DB_PASSWORD=postgres
EXTERNAL_DB_NAME=external_test

# ── Optional ─────────────────────────────────────────────────────────
# ECTO_IPV6=true
# DNS_CLUSTER_QUERY=
# POOL_SIZE=10
# MIX_TEST_PARTITION=
